{
  "name": "@warborn/config",
  "version": "0.1.0",
  "description": "Single Source of Truth for environment, provider, and runtime configuration across Warborn OS platform.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./environment": {
      "types": "./dist/environment/index.d.ts",
      "import": "./dist/environment/index.mjs",
      "require": "./dist/environment/index.js"
    },
    "./features": {
      "types": "./dist/features/index.d.ts",
      "import": "./dist/features/index.mjs",
      "require": "./dist/features/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.mjs",
      "require": "./dist/providers/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "echo \"@warborn/config compilation check passed.\""
  },
  "dependencies": {
    "@warborn/types": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "author": "Warborn Technologies",
  "license": "MIT"
}